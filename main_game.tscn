[sub_resource type="Shader" id="Shader_ykeeq"]
code = "shader_type canvas_item;

uniform float darkness : hint_range(0.0, 1.0) = 0.0;
uniform vec2 player_pos;
uniform float hole_radius = 200.0;
uniform float hole_softness = 100.0;
uniform mat3 camera_xform;

void fragment() {
	vec4 tex = texture(TEXTURE, UV);
	vec3 darkened = tex.rgb * (1.0 - darkness);
	vec2 screen_pos = SCREEN_UV * SCREEN_PIXEL_SIZE;
	vec2 world_pos = (camera_xform * vec3(screen_pos, 1.0)).xy; 
	float dist = distance(world_pos, player_pos);
	float mask = smoothstep(hole_radius + hole_softness, hole_radius, dist);
	vec3 final_color = mix(tex.rgb, darkened, mask);
	COLOR = vec4(final_color, tex.a);
}"

